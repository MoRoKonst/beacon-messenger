# Скопируй этот файл в .env и заполни значения:
#   cp .env.example .env

# Обязательно — секрет для создания каналов через Admin API
# Сгенерировать: python3 -c "import secrets; print(secrets.token_hex(32))"
CHANNEL_ADMIN_SECRET=замените_на_случайный_секрет

# Опционально — федерация между серверами (оставь пустым если не нужно)
#
# FEDERATION_SECRET — общий секрет на ВСЕХ серверах (отец + сыновья). Одинаковый!
#   Сгенерировать: python3 -c "import secrets; print(secrets.token_hex(32))"
FEDERATION_SECRET=
#
# FEDERATION_PEERS — статический список пиров (только для отца, если нет peer_announce).
#   Пример: wss://peer1.example.com,wss://peer2.example.com:4433
FEDERATION_PEERS=
#
# SERVER_URL — публичный WebSocket-адрес ЭТОГО сервера.
#   Нужен сыновьям: при подключении к отцу сын сообщает свой адрес через peer_announce,
#   чтобы клиенты получали актуальный список резервных серверов.
#   Пример: wss://myserver.ru  или  wss://myserver.ru:4433
SERVER_URL=
